{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "node": "20.19.0",
      "env": {
        "EAS_SKIP_EXPO_DOCTOR": "1",
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EAS_SKIP_EXPO_DOCTOR": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
