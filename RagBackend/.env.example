# ================================================================
# KnowledgeRAG 后端环境变量配置
# 使用方法：将本文件复制为 .env，并填入你自己的实际值
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)
# ================================================================

# ── 数据库配置 ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=mysql
DB_CHARSET=utf8mb4

# ── JWT 密钥（生产环境务必替换为随机强密钥）────────────────────
JWT_SECRET=changeme_jwt_secret_please_replace_in_production

# ── SMTP 邮件配置（用于发送验证码邮件）──────────────────────────
# 以 QQ 邮箱为例：授权码在 QQ 邮箱「设置 → 账户 → POP3/SMTP服务」中生成
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com

# ── QQ 互联 OAuth2.0（可选，不配置则 QQ 登录不可用）────────────
# 在 https://connect.qq.com 申请应用后填写
QQ_APP_ID=your_qq_app_id
QQ_APP_KEY=your_qq_app_key
# 回调地址须与 QQ 互联后台填写的完全一致（含路径）
# 本地开发示例：http://localhost:8000/api/qq/callback
# 生产环境示例：https://your-domain.com/api/qq/callback
QQ_REDIRECT_URI=http://localhost:8000/api/qq/callback

# ── 前端地址（QQ 登录成功后跳转目标）────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── 短信配置（可选，用于手机验证码）────────────────────────────
# SMS_ACCESS_KEY_ID=your_access_key
# SMS_ACCESS_KEY_SECRET=your_secret
# SMS_SIGN_NAME=your_sign_name
# SMS_TEMPLATE_CODE=your_template_code
