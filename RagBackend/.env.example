# ============================================================
# KnowledgeRAG-GZHU 后端环境变量配置模板
# 复制此文件为 .env 并填入真实值，不要将 .env 提交到 Git
# ============================================================

# 数据库配置
DB_HOST=172.22.121.2
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_strong_password_here
DB_NAME=mysql
DB_CHARSET=utf8mb4

# JWT 安全密钥（请替换为至少32位的随机字符串）
JWT_SECRET=your_very_long_random_jwt_secret_here

# Ollama 服务地址
OLLAMA_BASE_URL=http://localhost:11434

# 向量存储路径（可选，默认由各知识库自动管理）
# VECTORSTORE_PATH=./vectorstore

# 模型配置（可选，默认从 models_config.json 读取）
# MODEL=qwen2:7b
