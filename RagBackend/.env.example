# 数据库配置（复制此文件为 .env 并填入实际值）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=mysql
DB_CHARSET=utf8mb4

# SMTP 邮件配置（用于发送验证码邮件）
# 以 QQ 邮箱为例：授权码在 QQ 邮箱「设置 → 账户 → POP3/SMTP服务」中生成
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com

# 短信配置（可选，用于手机验证码）
# SMS_ACCESS_KEY_ID=your_access_key
# SMS_ACCESS_KEY_SECRET=your_secret
# SMS_SIGN_NAME=your_sign_name
# SMS_TEMPLATE_CODE=your_template_code
